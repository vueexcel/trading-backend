# Copy to .env and fill in. Never commit .env.

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
# Service role key: use ONLY for trusted backend operations (e.g., private storage signing)
SUPABASE_SERVICE_ROLE_KEY=
# Public frontend base URL used for auth email redirects
FRONTEND_URL=http://localhost:5173

# Google Cloud / BigQuery — pick ONE:
# (A) Base64-encoded service account JSON (recommended for deploys)
# Run: node scripts/print-google-credentials-b64.js
GOOGLE_SERVICE_ACCOUNT_B64=
# (B) Or omit the above and use local service-account.json (not in git)

# Project id (optional if JSON includes project_id)
GOOGLE_CLOUD_PROJECT=

# Legacy alias (still supported): same value as GOOGLE_SERVICE_ACCOUNT_B64
# ACCESS_TOKEN=

# Snapshot serving/read path controls
# ENABLE_MARKET_SNAPSHOT_READ=1
# ENABLE_MARKET_SNAPSHOT_REFRESH=1
# MARKET_SNAPSHOT_REFRESH_MS=300000
# BIGQUERY_SNAPSHOT_DATASET=sp500data1
# TICKER_DETAILS_SNAPSHOT_TABLE=ticker_details_snapshot
# INDEX_MARKET_MOVERS_SNAPSHOT_TABLE=index_market_movers_snapshot
# INDEX_RETURNS_SNAPSHOT_TABLE=index_returns_snapshot
# TICKER_DETAILS_SYMBOL_COLUMN=Symbol
# ENABLE_RELATIVE_VOLUME_QUERY=0

# API response cache (Upstash Redis: REDIS_URL + REDIS_TOKEN in .env)
# POST /api/market/ticker-returns — seconds (default 300). Lower for testing cache expiry.
# TICKER_RETURNS_CACHE_TTL_SECS=300
# Prewarm ticker-returns cache for popular symbols at startup + interval.
# ENABLE_TICKER_RETURNS_PREWARM=1
# TICKER_RETURNS_PREWARM_TICKERS=AAPL,MSFT,NVDA
# TICKER_RETURNS_PREWARM_INTERVAL_MS=300000
# On cache-miss requests (non-custom range), queue a background warmup for defaults
# and optionally requested symbols. Does not block the API response.
# ENABLE_TICKER_RETURNS_ON_DEMAND_PREWARM=1
# INCLUDE_REQUESTED_TICKERS_IN_PREWARM=1
# Block server startup until initial ticker-returns prewarm finishes (or timeout).
# ENABLE_TICKER_RETURNS_STARTUP_BLOCK=1
# TICKER_RETURNS_STARTUP_BLOCK_TIMEOUT_MS=30000

# Optional: set to 1 to skip writing `Tickeer_Weights` when running fetch-slickcharts-weights.js
# SKIP_BIGQUERY_WEIGHTS_SYNC=

# Optional: allow using last saved index-weights.json when remote fetch is blocked (default: enabled)
# Set to 0 to fail hard instead of using stale data.
# ALLOW_STALE_WEIGHTS_ON_FAILURE=
