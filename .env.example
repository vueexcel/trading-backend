# Copy to .env and fill in. Never commit .env.

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Google Cloud / BigQuery — pick ONE:
# (A) Base64-encoded service account JSON (recommended for deploys)
# Run: node scripts/print-google-credentials-b64.js
GOOGLE_SERVICE_ACCOUNT_B64=
# (B) Or omit the above and use local service-account.json (not in git)

# Project id (optional if JSON includes project_id)
GOOGLE_CLOUD_PROJECT=

# Legacy alias (still supported): same value as GOOGLE_SERVICE_ACCOUNT_B64
# ACCESS_TOKEN=

# Optional: set to 1 to skip writing `Tickeer_Weights` when running fetch-slickcharts-weights.js
# SKIP_BIGQUERY_WEIGHTS_SYNC=

# Optional: allow using last saved index-weights.json when remote fetch is blocked (default: enabled)
# Set to 0 to fail hard instead of using stale data.
# ALLOW_STALE_WEIGHTS_ON_FAILURE=
